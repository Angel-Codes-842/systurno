# Configuración de Nginx para Sistema de Recepción de Pacientes
# Copiar a: /etc/nginx/sites-available/clinica

upstream django_backend {
    server 127.0.0.1:8000;
}

server {
    listen 80;
    server_name 192.168.1.100 clinica.local;  # Ajustar según tu IP/dominio
    
    client_max_body_size 10M;
    
    # Frontend - Archivos estáticos de React
    root /ruta/al/proyecto/frontend/dist;  # Ajustar ruta
    index index.html;
    
    # Logs
    access_log /var/log/nginx/clinica_access.log;
    error_log /var/log/nginx/clinica_error.log;
    
    # Frontend - SPA routing
    location / {
        try_files $uri $uri/ /index.html;
    }
    
    # Backend API
    location /api {
        proxy_pass http://django_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_redirect off;
    }
    
    # Django Admin
    location /admin {
        proxy_pass http://django_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
    
    # WebSocket
    location /ws {
        proxy_pass http://django_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 86400;
    }
    
    # Archivos estáticos de Django
    location /static/ {
        alias /ruta/al/proyecto/backend/staticfiles/;  # Ajustar ruta
        expires 30d;
        add_header Cache-Control "public, immutable";
    }
    
    # Cache para assets del frontend
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
}

