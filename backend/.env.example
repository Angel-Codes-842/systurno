# Django Settings
DEBUG=True
SECRET_KEY=django-insecure-CHANGE-THIS-IN-PRODUCTION
ALLOWED_HOSTS=*

# ============================================
# Base de Datos - Elige una opción
# ============================================

# Opción 1: SQLite (Desarrollo - Por defecto)
# Descomenta esta línea para usar SQLite:
DB_ENGINE=django.db.backends.sqlite3

# Opción 2: PostgreSQL (Producción - Recomendado)
# Descomenta estas líneas y comenta la de SQLite:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=clinica_db
# DB_USER=clinica_user
# DB_PASSWORD=tu_password_seguro
# DB_HOST=localhost
# DB_PORT=5432

# ============================================
# Redis (Opcional - para WebSockets en producción)
# ============================================
USE_REDIS=False
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# CORS (ajustar según tu red)
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
